{
    "name": "@smooai/smooth",
    "version": "0.1.0",
    "private": true,
    "packageManager": "pnpm@10.6.1",
    "scripts": {
        "build": "turbo run build --filter='!@smooai/smooth'",
        "dev": "turbo run dev --filter='!@smooai/smooth'",
        "test": "turbo run test --filter='!@smooai/smooth'",
        "typecheck": "turbo run typecheck --filter='!@smooai/smooth'",
        "lint": "oxlint --config .oxlintrc.json .",
        "lint:fix": "oxlint --config .oxlintrc.json --fix .",
        "format": "oxfmt --write .",
        "format:check": "oxfmt --check .",
        "sync": "syncpack fix-mismatches",
        "pre-commit-check": "pnpm sync && pnpm lint:fix && pnpm typecheck && pnpm test && pnpm format",
        "check-all": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm test && pnpm build",
        "changeset": "changeset",
        "db:generate": "pnpm --filter @smooai/smooth-db generate",
        "db:migrate": "pnpm --filter @smooai/smooth-db migrate",
        "leader:dev": "pnpm --filter @smooai/smooth-leader dev"
    },
    "devDependencies": {
        "@changesets/cli": "^2.29.4",
        "oxfmt": "^0.12.0",
        "oxlint": "^1.57.0",
        "syncpack": "^13.0.0",
        "turbo": "^2.5.0",
        "typescript": "^5.8.3",
        "vite-tsconfig-paths": "^5.1.0",
        "vitest": "^3.1.0"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "better-sqlite3",
            "esbuild"
        ]
    }
}