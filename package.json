{
    "name": "@smooth/smooth",
    "version": "0.1.0",
    "private": true,
    "packageManager": "pnpm@10.6.1",
    "scripts": {
        "build": "turbo run build",
        "dev": "turbo run dev",
        "test": "turbo run test",
        "typecheck": "turbo run typecheck",
        "lint": "oxlint --config .oxlintrc.json .",
        "lint:fix": "oxlint --config .oxlintrc.json --fix .",
        "format": "oxfmt --write .",
        "format:check": "oxfmt --check .",
        "sync": "syncpack fix-mismatches",
        "pre-commit-check": "pnpm sync && pnpm lint:fix && pnpm typecheck && pnpm test && pnpm format",
        "check-all": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm test && pnpm build",
        "changeset": "changeset",
        "db:generate": "pnpm --filter @smooth/db generate",
        "db:migrate": "pnpm --filter @smooth/db migrate",
        "postgres:up": "docker compose -f docker/docker-compose.yml up -d postgres",
        "postgres:down": "docker compose -f docker/docker-compose.yml down",
        "postgres:logs": "docker compose -f docker/docker-compose.yml logs -f postgres",
        "postgres:ps": "docker compose -f docker/docker-compose.yml ps",
        "leader:dev": "pnpm --filter @smooth/leader dev"
    },
    "devDependencies": {
        "@changesets/cli": "^2.29.4",
        "oxfmt": "^0.12.0",
        "oxlint": "^1.57.0",
        "syncpack": "^13.0.0",
        "turbo": "^2.5.0",
        "typescript": "^5.8.3"
    }
}
