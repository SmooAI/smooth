{
    "plugins": ["typescript", "react", "react-hooks", "import", "nextjs"],
    "categories": {
        "correctness": "error",
        "suspicious": "warn",
        "pedantic": "off",
        "style": "off"
    },
    "rules": {
        "no-unused-vars": "off",
        "@typescript-eslint/no-unused-vars": [
            "warn",
            {
                "argsIgnorePattern": "^_",
                "varsIgnorePattern": "^_"
            }
        ],
        "react-hooks/rules-of-hooks": "error",
        "react-hooks/exhaustive-deps": "warn"
    },
    "ignorePatterns": ["node_modules", "dist", ".next", ".turbo", "docker"]
}
