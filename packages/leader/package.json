        "@langchain/langgraph": "^1.2.0",
        "@langchain/langgraph-checkpoint-sqlite": "^1.0.0",
        "hono": "^4.7.0",
        "@hono/node-server": "^1.14.0",
        "zod": "^4.0.0"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "tsup": "^8.4.0",
        "tsx": "^4.19.0",
        "typescript": "^5.8.3",
