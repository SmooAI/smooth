{
    "compilerOptions": {
        "strict": true,
        "strictNullChecks": true,
        "declaration": true,
        "declarationMap": true,
        "esModuleInterop": true,
        "isolatedModules": true,
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "skipLibCheck": true,
        "noEmit": true,
        "target": "ES2022",
        "lib": ["ES2023"],
        "outDir": "./dist",
        "baseUrl": "./",
        "paths": {
            "@smooai/smooth-shared/*": ["packages/shared/src/*"],
            "@smooai/smooth-db/*": ["packages/db/src/*"],
            "@smooai/smooth-auth/*": ["packages/auth/src/*"],
            "@smooai/smooth-smoo-api/*": ["packages/smoo-api/src/*"],
            "@smooai/smooth-leader/*": ["packages/leader/src/*"],
            "@smooai/smooth-cli/*": ["packages/cli/src/*"],
            "@smooai/smooth-tools/*": ["packages/tools/src/*"]
        }
    },
    "include": ["./**/*.ts", "./**/*.tsx"],
    "exclude": ["dist", "node_modules", "*.js"]
}
