# Smooth Operator Sandboxfile — for use with Microsandbox
# This defines the default sandbox configuration for Smooth Operators.
# The leader's LocalMicrosandboxBackend overrides these via CLI args.

[sandbox.operator]
image = "smooth-operator:latest"
memory = 4096
cpus = 2

[sandbox.operator.scripts]
start = "/entrypoint.sh"

[sandbox.operator.env]
SMOOTH_MCP_SOCKET = "/tmp/smooth-tools.sock"
