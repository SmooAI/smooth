# Smooth Operator image with the Node.js / pnpm toolchain baked in.
#
# Picks up where smooai/operator leaves off: that image is 35MB alpine
# + the runner, which is enough to edit files but not enough to run
# `pnpm dev` / `turbo dev` / `vite`. This variant is what you want
# when the agent needs to actually execute a JS/TS project inside the
# sandbox and expose a dev-server port back to the host.
#
# Build: scripts/build-operator-node-image.sh
#
# Layers on top of node:20-alpine rather than our plain alpine base
# so we inherit a known-good Node runtime + npm. Corepack enables
# `pnpm` without a separate install step. The operator runner is
# copied last so the Node layers stay cached across runner rebuilds.
FROM node:20-alpine

# ca-certificates for outbound HTTPS (LLM providers via the Goalie
# proxy). git because the vast majority of `pnpm install` / tooling
# flows want it. bash for agent-friendly shells; alpine ships ash by
# default and some tool scripts assume bash. tini as PID 1 so dev
# servers that fork children get cleaned up properly.
RUN apk add --no-cache ca-certificates git bash tini \
    && corepack enable \
    && corepack prepare pnpm@10 --activate

# Bind-mounts typically land under /workspace (repo) + /opt/smooth/cache
# (project-scoped sandbox cache bind). Creating them up front means
# the runner doesn't race to mkdir while Bill sets mounts up.
RUN mkdir -p /workspace /opt/smooth/cache
WORKDIR /workspace

# pnpm content-addressed store lands under /opt/smooth/cache, which
# Bill bind-mounts from ~/.smooth/project-cache/<key>/ on the host.
# Repeated `pnpm install`s across runs share packages via the store.
# uv + cargo + go get equivalent vars if/when we add those images.
ENV PNPM_HOME=/opt/smooth/cache/pnpm-store \
    PNPM_STORE_PATH=/opt/smooth/cache/pnpm-store \
    PATH=/opt/smooth/bin:/opt/smooth/cache/pnpm-store:$PATH

# Operator runner — copied after system deps so base layers stay
# cached across runner rebuilds.
COPY target/aarch64-unknown-linux-musl/release/smooth-operator-runner /opt/smooth/bin/smooth-operator-runner

ARG VERSION=dev
LABEL org.opencontainers.image.title="smooai-operator-node" \
      org.opencontainers.image.description="Smooth Operator with Node 20 + pnpm 10" \
      org.opencontainers.image.source="https://github.com/SmooAI/smooth" \
      org.opencontainers.image.version="${VERSION}"

# tini as PID 1, runner as the actual command so it reaps dev-server
# child processes cleanly when the VM is torn down.
ENTRYPOINT ["/sbin/tini", "--", "/opt/smooth/bin/smooth-operator-runner"]
