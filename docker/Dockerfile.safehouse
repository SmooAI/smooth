# Safehouse image — the microVM Bootstrap Bill spawns for Big Smooth
# itself when `th up` boots into sandboxed mode (`SMOOTH_SAFEHOUSE_MODE=1`).
#
# The `safehouse` binary embeds Archivist, Scribe, Wonk, Goalie, and
# the Safehouse Narc as library crates (see
# smooth_bigsmooth::safehouse::spawn_safehouse_cast), all running as
# tokio tasks inside the same process. That leaves just two binaries
# to ship:
#
#   - safehouse        — Big Smooth + in-process cast
#   - smooth-dolt      — pearl store backend (Go/Dolt engine)
#
# Build with: scripts/build-safehouse-image.sh
#
# Expected build context: the repo root. The caller must run
# scripts/build-safehouse.sh first so both binaries exist at
# target/aarch64-unknown-linux-musl/release/.
FROM alpine:3.20

# ca-certificates: outbound HTTPS verification (LLM providers, etc.).
# ICU libs: smooth-dolt embeds parts of the Dolt engine that want
# libicuuc/data at runtime in some code paths.
RUN apk add --no-cache ca-certificates icu-libs

WORKDIR /root

COPY target/aarch64-unknown-linux-musl/release/safehouse /opt/smooth/bin/safehouse
COPY target/aarch64-unknown-linux-musl/release/smooth-dolt /opt/smooth/bin/smooth-dolt

ARG VERSION=dev
LABEL org.opencontainers.image.title="smooai-safehouse" \
      org.opencontainers.image.description="Smooth Safehouse (Big Smooth + in-process cast)" \
      org.opencontainers.image.source="https://github.com/SmooAI/smooth" \
      org.opencontainers.image.version="${VERSION}"

ENV PATH="/opt/smooth/bin:${PATH}"
# Wrap in /bin/sh (no exec) so safehouse runs as PID 2 rather than
# PID 1. As PID 1, tokio + tracing's stderr produced an empty
# guest.log under microsandbox's detached-sandbox path (likely a
# libc init / PID-1 signal-handling interaction). Keeping sh as
# init lets safehouse's stderr flow normally.
ENTRYPOINT ["/bin/sh", "-c", "/opt/smooth/bin/safehouse"]
